---
import ResumeNav from '../../ResumeNav.astro';
import ResumeSection from '../../ResumeSection.astro';
import SummaryPills from '../../SummaryPills.astro';
import ProfileMetaGrid from '../../ProfileMetaGrid.astro';
import InviteFragmentRedirect from '../../InviteFragmentRedirect.astro';
import {
  joinResumeSummary,
  normalizeResumeSummary,
  type ResumeSummary,
} from '../../../lib/resume-summary';
import { getCanonicalUrl, withBase } from '../../../lib/site';
import '../../../styles/resume-themes/glass-web.css';

interface ResumeEntry {
  data: {
    title: string;
    subtitle?: string;
    summary?: ResumeSummary;
    sectionSlug: string;
    layout: 'full' | 'compact';
  };
  Content: any;
}

interface Props {
  hero: {
    data: {
      title: string;
      subtitle?: string;
      summary?: ResumeSummary;
      contacts?: Array<{
        label?: string;
        value?: string;
        href?: string;
      }>;
    };
    Content: any;
  };
  navItems: Array<{
    href: string;
    label: string;
  }>;
  sections: ResumeEntry[];
  primarySection?: ResumeEntry | null;
  kicker?: string;
  printHref: string;
  redirectInviteFragment?: boolean;
}

const { hero, navItems, sections, primarySection, kicker, printHref, redirectInviteFragment = false } = Astro.props;
const heroSummaryText =
  typeof hero.data.summary === 'string' ? joinResumeSummary(hero.data.summary) : undefined;
const heroSummaryItems =
  Array.isArray(hero.data.summary) ? normalizeResumeSummary(hero.data.summary) : [];
const pageDescription = joinResumeSummary(hero.data.summary) ?? '简历内容';
const mainSections = sections.filter((section) => section.data.layout === 'full');
const sideSections = sections.filter((section) => section.data.layout !== 'full');
const primaryActionHref = primarySection ? `#${primarySection.data.sectionSlug}` : '#top';
const primaryActionLabel = primarySection ? `查看${primarySection.data.title}` : '查看简历';
const canonicalUrl = getCanonicalUrl(Astro.url, Astro.site);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <InviteFragmentRedirect enabled={redirectInviteFragment} unlockPath={withBase('/unlock')} />
    <title>{hero.data.title} | 简历</title>
  </head>
  <body class="glass-web-body">
    <ResumeNav
      name={hero.data.title}
      subtitle={hero.data.subtitle}
      items={navItems}
      printHref={printHref}
    />

    <main class="resume-page" id="top">
      <div class="resume-page-noise" aria-hidden="true"></div>

      <section class="resume-hero">
        <div class="resume-hero-copy">
          {kicker && <p class="resume-hero-kicker">{kicker} / Resume</p>}
          <h1 class="resume-hero-title">{hero.data.title}</h1>
          {hero.data.subtitle && <p class="resume-hero-role">{hero.data.subtitle}</p>}
          {heroSummaryText && <p class="resume-hero-summary">{heroSummaryText}</p>}
          {heroSummaryItems.length > 0 && (
            <SummaryPills
              items={heroSummaryItems}
              className="resume-hero-summary-pills"
              itemClassName="resume-hero-summary-pill"
            />
          )}

          <div class="resume-hero-actions">
            <a class="resume-button resume-button-primary" href={primaryActionHref}>
              {primaryActionLabel}
            </a>
            <a class="resume-button resume-button-secondary" href={printHref} target="_blank" rel="noreferrer">
              打印版 / PDF
            </a>
          </div>
        </div>

        <div class="resume-hero-panel">
          <ProfileMetaGrid
            contacts={hero.data.contacts}
            variant="web"
          />
          <hero.Content />
        </div>
      </section>

      <section class="resume-layout">
        <div class="resume-main">
          {
            mainSections.map((section) => (
              <ResumeSection
                id={section.data.sectionSlug}
                title={section.data.title}
                subtitle={section.data.subtitle}
                summary={section.data.summary}
                slug={section.data.sectionSlug}
                layout={section.data.layout}
                tone="primary"
              >
                <section.Content />
              </ResumeSection>
            ))
          }
        </div>

        <aside class="resume-sidebar">
          {
            sideSections.map((section) => (
              <ResumeSection
                id={section.data.sectionSlug}
                title={section.data.title}
                subtitle={section.data.subtitle}
                summary={section.data.summary}
                slug={section.data.sectionSlug}
                layout={section.data.layout}
                tone="secondary"
              >
                <section.Content />
              </ResumeSection>
            ))
          }
        </aside>
      </section>
    </main>
  </body>
</html>
