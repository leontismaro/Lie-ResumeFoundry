---
import SummaryPills from './SummaryPills.astro';
import {
  joinResumeSummary,
  normalizeResumeSummary,
  type ResumeSummary,
} from '../lib/resume-summary';

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  summary?: ResumeSummary;
  slug: string;
  layout?: 'full' | 'compact';
  tone?: 'primary' | 'secondary';
}

const {
  id,
  title,
  subtitle,
  summary,
  slug,
  layout = 'compact',
  tone = 'secondary',
} = Astro.props;
const summaryText = typeof summary === 'string' ? joinResumeSummary(summary) : undefined;
const summaryItems = Array.isArray(summary) ? normalizeResumeSummary(summary) : [];
---

<section
  id={id}
  class:list={[
    'resume-section',
    `resume-section-${slug}`,
    `resume-section-layout-${layout}`,
    `resume-section-tone-${tone}`,
  ]}
>
  <header class="resume-section-header">
    <p class="resume-section-kicker">{tone === 'primary' ? 'Highlights' : 'Details'}</p>
    <h2 class="resume-section-title">{title}</h2>
    {subtitle && <p class="resume-section-subtitle">{subtitle}</p>}
    {summaryText && <p class="resume-section-summary">{summaryText}</p>}
    {summaryItems.length > 0 && (
      <SummaryPills
        items={summaryItems}
        className="resume-section-summary-pills"
        itemClassName="resume-section-summary-pill"
      />
    )}
  </header>

  <div class="resume-section-body">
    <slot />
  </div>
</section>
