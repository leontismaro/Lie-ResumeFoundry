---
import { joinResumeSummary, type ResumeSummary } from '../lib/resume-summary';

interface Props {
  title: string;
  summary?: ResumeSummary;
  slug: string;
}

const { title, summary, slug } = Astro.props;
const summaryText = joinResumeSummary(summary, ' · ');
---

<section class:list={['print-section', `print-section-${slug}`]}>
  <header class="print-section-header">
    <h2 class="print-section-title">{title}</h2>
    {summaryText && <p class="print-section-summary">{summaryText}</p>}
  </header>

  <div class="print-section-body">
    <slot />
  </div>
</section>
