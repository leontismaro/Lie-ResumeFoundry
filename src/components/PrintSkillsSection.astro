---
import { joinResumeSummary, type ResumeSummary } from '../lib/resume-summary';

interface SkillGroup {
  name: string;
  items: string[];
}

interface Props {
  title: string;
  summary?: ResumeSummary;
  groups: SkillGroup[];
}

const { title, summary, groups } = Astro.props;
const summaryText = joinResumeSummary(summary, ' · ');
---

<section class:list={['print-section', 'print-section-skills']}>
  <header class="print-section-header">
    <h2 class="print-section-title">{title}</h2>
    {summaryText && <p class="print-section-summary">{summaryText}</p>}
  </header>

  <div class="print-section-body">
    <div class="print-skill-grid">
      {
        groups.map((group) => (
          <>
            <h3 class="print-skill-name">{group.name}</h3>
            <p class="print-skill-items">{group.items.join(' · ')}</p>
          </>
        ))
      }
    </div>
  </div>
</section>
