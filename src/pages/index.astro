---
import ResumeStyleRenderer from '../components/ResumeStyleRenderer.astro';
import { loadResumeContent } from '../lib/resume';
import { getMasterResumeDefinition, getResumePath } from '../lib/resume-catalog';

const definition = await getMasterResumeDefinition();
const { hero, styleId, navItems, sections, primarySection } = await loadResumeContent(definition.id);

const printHref = getResumePath(definition.id, {
  print: true,
  preferMasterRoot: true,
  isMaster: definition.isMaster,
});
---

<ResumeStyleRenderer
  styleId={styleId}
  variant="web"
  hero={hero}
  navItems={navItems}
  sections={sections}
  primarySection={primarySection}
  kicker={definition.kicker}
  printHref={printHref}
  redirectInviteFragment
/>
