# 本文件是本地 wrangler 开发环境变量示例。
# 复制为 ".dev.vars" 后，wrangler pages dev 会自动读取。

# 本地浏览器里 session cookie 的名称。
# 语义：如果以后同域下还有别的站点，可以通过改名避免 cookie 冲突。
AUTH_COOKIE_NAME=resume_session

# 登录成功后的 session 有效期，单位秒。
# 语义：浏览器在这段时间内再次访问 "/"、"/print" 时不需要重新扫码。
# 1209600 秒 = 14 天。
AUTH_SESSION_TTL_SECONDS=1209600

# 生成二维码时的默认 token 有效期，单位秒。
# 语义：仅影响发码脚本的默认值；脚本里也可以用 --ttl-minutes 覆盖。
# 900 秒 = 15 分钟。
AUTH_QR_DEFAULT_TTL_SECONDS=900

# /auth/qr 在一个时间窗口内允许的最大失败尝试次数。
AUTH_QR_RATE_LIMIT_MAX_ATTEMPTS=8

# /auth/qr 失败尝试的统计窗口，单位秒。
# 达到阈值后，会在这个窗口时长内临时阻止继续尝试。
AUTH_QR_RATE_LIMIT_WINDOW_SECONDS=600

# 明确公开放行的路径，使用英文逗号分隔。
# 精确路径直接写路径；前缀路径请写成 "/*" 形式，例如 "/_astro/*"。
# 语义：除这些路径和带扩展名的静态资源外，其余页面路径默认都需要 session。
AUTH_PUBLIC_PATHS=/unlock,/auth/qr,/auth/logout,/_astro/*,/favicon.ico,/favicon.svg

# 后台入口目录。建议上线前替换成你自己的长随机路径。
ADMIN_BASE_PATH=/internal-console/8d98fa5f0df14cabae1ddf37cb6ef4f5

# 后台鉴权模式：
# local：使用本项目中间件与后台密码
# access：仅使用 Cloudflare Access
# access_with_local_fallback：Access JWT 优先，无 JWT 时回退后台密码
ADMIN_AUTH_MODE=local

# 本地示例密码为 local-admin-pass。生产环境必须替换。
ADMIN_PASSWORD_HASH="pbkdf2-sha256$310000$I5fTp2hu1k1yohDupDI38C6At8coqZ53$tt8DkcIyFEfvNSoB6fZarhJobsIi6fmGyPLhydxaXwM"

# 后台管理员显示名称。
ADMIN_USER_EMAIL=local-admin@example.com

# 后台登录 session 有效期，单位秒。28800 秒 = 8 小时。
ADMIN_SESSION_TTL_SECONDS=28800

# 后台登录失败限流。
ADMIN_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=600

# Cloudflare Access 应用域名，例如 https://example.cloudflareaccess.com
ADMIN_ACCESS_DOMAIN=https://replace-with-your-team.cloudflareaccess.com

# Cloudflare Access 应用对应的 Audience（aud）
ADMIN_ACCESS_AUD=replace-with-your-access-audience
